# ─────────────────────────────────────────────
# Order Service — Environment Variables
# ─────────────────────────────────────────────

# PostgreSQL
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/order_db"

# JWT — must be the SAME secret as auth-service
JWT_SECRET="your-super-secret-jwt-key-shared-with-auth-service"

# Inter-service communication
BOOK_SERVICE_URL="http://book-service:8000"

# Server
PORT=3002
NODE_ENV="development"

# Observability
SERVICE_NAME="order-service"
SERVICE_VERSION="1.0.0"
OTEL_EXPORTER_OTLP_ENDPOINT="http://alloy:4317"
LOKI_HOST="http://loki:3100"
